SET sql_mode='ORACLE';
SET lc_time_names='en_US';
SELECT TO_DATE('2002 - AD', 'YYYY AD');
TO_DATE('2002 - AD', 'YYYY AD')
2002-00-00 00:00:00
SELECT TO_DATE('2024---01---01', 'YYYYMMDD');
TO_DATE('2024---01---01', 'YYYYMMDD')
2024-01-01 00:00:00
SELECT TO_DATE('2024 . 05 . 10', 'YYYYMMDD');
TO_DATE('2024 . 05 . 10', 'YYYYMMDD')
2024-05-10 00:00:00
SELECT TO_DATE('2002 - February - 10', 'YYYY MONTH DD');
TO_DATE('2002 - February - 10', 'YYYY MONTH DD')
2002-02-10 00:00:00